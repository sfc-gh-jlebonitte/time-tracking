# Snowhouse (Snowflake) connection — copy to snowhouse.env and fill in values
# The script loads this file automatically on startup.

SNOWHOUSE_SNOWFLAKE_ACCOUNT=SFCOGSOPS-SNOWHOUSE_AWS_US_WEST_2
SNOWHOUSE_SNOWFLAKE_USER=your.name@snowflake.com
SNOWHOUSE_SNOWFLAKE_WAREHOUSE=SE_WH
SNOWHOUSE_SNOWFLAKE_DATABASE=
SNOWHOUSE_SNOWFLAKE_SCHEMA=
SNOWHOUSE_SNOWFLAKE_ROLE=

# Your display name as it appears in Gong and Salesforce SE reporting.
# If not set, it is automatically derived from your email address
# (e.g. john.doe@snowflake.com → "John Doe").
# Set this explicitly if your display name differs from your email.
# SNOWFLAKE_SE_NAME=John Doe

# Optional: set to skip the browser SSO popup (required for unattended cron)
# SNOWHOUSE_SNOWFLAKE_PASSWORD=
# SNOWHOUSE_SNOWFLAKE_AUTHENTICATOR=snowflake
